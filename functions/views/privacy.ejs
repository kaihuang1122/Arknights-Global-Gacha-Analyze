<!DOCTYPE html>
<html lang="<%= lang === 'zh-tw' ? 'zh-Hant' : lang === 'zh-cn' ? 'zh-Hans' : lang === 'ja-jp' ? 'ja' : 'en' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" />
  <meta name="referrer" content="no-referrer">
  <title><%= t('privacy_title') %></title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    body {
      background-color: #000000;
      color: #e0e0e0;
      font-family: "Noto Sans JP", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      line-height: 1.6;
      margin: 0;
      padding: 0;
    }
    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 2rem;
    }
    h1 {
      color: #1bd1fe;
      margin-bottom: 2rem;
      border-bottom: 2px solid #333;
      padding-bottom: 0.5rem;
    }
    h2 {
      color: #fff;
      margin-top: 2rem;
    }
    p {
      color: #bbb;
      margin-bottom: 1rem;
    }
    ul {
      color: #bbb;
      margin-bottom: 1rem;
      padding-left: 1.5rem;
    }
    li {
      margin-bottom: 0.5rem;
    }
    a {
      color: #1bd1fe;
      text-decoration: none;
    }
    a:hover {
      text-decoration: underline;
    }
    .back-btn {
      display: inline-block;
      margin-bottom: 2rem;
      padding: 0.5rem 1rem;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 4px;
      color: #fff;
    }
    .back-btn:hover {
      background: rgba(255, 255, 255, 0.2);
    }
  </style>
</head>
<body>
  <div class="container">
    <a href="/login" class="back-btn"><%= t('back_home') %></a>
    
    <div style="position: absolute; top: 1rem; right: 1rem; z-index: 100;">
      <select onchange="window.location.href='?lang='+this.value" style="background: rgba(255,255,255,0.1); color: #fff; border: 1px solid #333; padding: 0.3rem; border-radius: 4px;">
        <option value="zh-tw" <%= lang === 'zh-tw' ? 'selected' : '' %>>繁體中文</option>
        <option value="zh-cn" <%= lang === 'zh-cn' ? 'selected' : '' %>>简体中文</option>
        <option value="ja-jp" <%= lang === 'ja-jp' ? 'selected' : '' %>>日本語</option>
        <option value="en-us" <%= lang === 'en-us' ? 'selected' : '' %>>English</option>
      </select>
    </div>
    <h1><%= t('privacy_h1') %></h1>
    
    <p><%= t('privacy_date') %></p>

    <h2><%= t('privacy_intro_title') %></h2>
    <p><%= t('privacy_intro_1') %></p>
    <p><%= t('privacy_intro_2') %></p>

    <h2><%= t('privacy_data_title') %></h2>
    <p><%= t('privacy_data_1') %></p>
    <ul>
      <li><%= t('privacy_data_2') %></li>
    </ul>

    <h2><%= t('privacy_use_title') %></h2>
    <ul>
      <li><%- t('privacy_use_1_title') %></li>
      <li><%- t('privacy_use_2_title') %></li>
      <li><%- t('privacy_use_3_title') %></li>
    </ul>

    <h2><%= t('privacy_transfer_title') %></h2>
    <p><%= t('privacy_transfer_1') %></p>
    <ul>
      <li><%- t('privacy_transfer_2_title') %></li>
      <li><%- t('privacy_transfer_3_title') %></li>
    </ul>

    <h2><%= t('privacy_ext_title') %></h2>
    <p><%= t('privacy_ext_1') %></p>
    <ul>
      <li><%- t('privacy_ext_2') %></li>
      <li><%- t('privacy_ext_3') %></li>
      <li><%- t('privacy_ext_4') %></li>
      <li><%- t('privacy_ext_5') %></li>
    </ul>

    <h2><%= t('privacy_rights_title') %></h2>
    <p><%= t('privacy_rights_1') %></p>
    <p><%= t('privacy_rights_2') %></p>
    <ol>
      <li><%= t('privacy_rights_3') %></li>
      <li><%= t('privacy_rights_4') %></li>
      <li><%- t('privacy_rights_5') %></li>
    </ol>

    <h2><%= t('privacy_contact_title') %></h2>
    <p><%- t('privacy_contact_1') %></p>
  </div>
</body>
</html>
