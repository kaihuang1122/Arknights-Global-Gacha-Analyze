<!DOCTYPE html>
<html lang="<%= lang === 'zh-tw' ? 'zh-Hant' : lang === 'zh-cn' ? 'zh-Hans' : lang === 'ja-jp' ? 'ja' : 'en' %>">
  <head>
    <meta name="google-site-verification" content="-r9-42OaiijcNFEbHg0HM3QdyfWyt6R-rEErIIRceak" />
    <meta name="keywords" content="Arknights, 明日方舟, 抽卡, 尋訪, 國際服, 悠星服, 英服, 美服, 日服, 韓服, 尋訪紀錄, 紀錄分析">
    <meta name="description" content="明日方舟悠星服（英文服、日文服、韓文服）尋訪紀錄分析工具，支持紀錄匯入、匯出、統計、圖表分析等功能">
    <meta charset="utf-8" />
    <meta http-equiv="pragma" content="no-cache" />
    <meta http-equiv="cache-control" content="no-cache" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="referrer" content="no-referrer">
    <title><%= t('login_title') %></title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="/css/your.css" />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
      body {
        font-family: "Noto Sans JP", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      }
      .login-wrapper {
        display: flex;
        gap: 2rem;
        justify-content: center;
        padding: 2rem;
        flex-wrap: wrap;
      }
      .login-box {
        background: #121212;
        padding: 1.5rem;
        border-radius: 0.5rem;
        flex: 1 1 300px;
        max-width: 25rem;
        display: flex;
        flex-direction: column;
      }
      .login-box form {
        display: flex;
        flex-direction: column;
        flex: 1;
      }
      .input-group {
        margin-bottom: 1rem;
      }
      .input-label {
        display: block;
        margin-bottom: 0.25rem;
      }
      .login-input {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #333;
        border-radius: 0.25rem;
        background: #000;
        color: #e0e0e0;
      }
      .login-textarea {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #333;
        border-radius: 0.25rem;
        background: #000;
        color: #e0e0e0;
        resize: vertical;
        font-family: monospace;
      }
      .submit-btn {
        width: 100%;
        padding: 0.75rem;
        background: #10d1fe;
        border: none;
        border-radius: 0.25rem;
        font-weight: bold;
        color: #000;
        cursor: pointer;
        margin-top: auto;
      }
      @media (max-width: 768px) {
        .login-wrapper {
          flex-direction: column;
          align-items: center;
          padding: 1rem;
        }
        .login-box {
          width: 100%;
          max-width: 100%;
        }
      }
    </style>
  </head>
  <body class="dark-mode" style="background-color: #000000; color: #e0e0e0">
    <!-- 大標題 -->
    <div style="position: absolute; top: 1rem; right: 1rem; z-index: 100;">
      <select onchange="window.location.href='?lang='+this.value" style="background: rgba(255,255,255,0.1); color: #fff; border: 1px solid #333; padding: 0.3rem; border-radius: 4px;">
        <option value="zh-tw" <%= lang === 'zh-tw' ? 'selected' : '' %>>繁體中文</option>
        <option value="zh-cn" <%= lang === 'zh-cn' ? 'selected' : '' %>>简体中文</option>
        <option value="ja-jp" <%= lang === 'ja-jp' ? 'selected' : '' %>>日本語</option>
        <option value="en-us" <%= lang === 'en-us' ? 'selected' : '' %>>English</option>
      </select>
    </div>
    <!-- 大標題 -->
    <div class="HgfD8Q" style="padding: 1.5rem; text-align: center">
      <div class="tshJ_L" style="font-size: 1.5rem">
        <%= t('main_heading') %>
      </div>
    </div>

    <!-- 最新消息 -->
    <div class="x82bAA">
      <div class="tshJ_L"><%= t('latest_news') %></div>
      <div class="ab1yWq">
        <div class="wYL2n2 Q25EOd"></div>
        <div class="wYL2n2 xW0Sk9"></div>
        <div class="wYL2n2 m8kOmo"></div>
        <div class="wYL2n2 Mric6f"></div>
        <div class="Xo6v7v">
          <div style="margin-bottom: 0.8rem; background-color: rgba(27, 209, 254, 0.15); border: 1px solid #1bd1fe; border-radius: 0.25rem; padding: 0.6rem; color: #fff;">
            <strong><%- t('news_content') %></strong>
          </div>

        </div>
      </div>
    </div>

    <!-- 登入區塊容器 -->
    <div class="login-wrapper">
      <!-- 方法一：Cookie + Token -->
      <div class="login-box">
        <div class="tshJ_L" style="margin-bottom: 1rem">
          <%= t('method_1_title') %>
        </div>
        <form id="cookieForm" method="post" action="/login">
          <input type="hidden" name="method" value="cookie" />
          <div class="input-group">
            <label class="input-label"><%= t('server_label') %></label>
            <select name="server" class="login-input" required>
              <option value="jp"><%= t('server_jp') %></option>
              <option value="en"><%= t('server_en') %></option>
              <option value="kr"><%= t('server_kr') %></option>
            </select>
          </div>
          <div class="input-group">
            <label class="input-label"><%= t('cookie_label') %></label>
            <textarea name="yssid" class="login-textarea" required rows="2"></textarea>
          </div>
          <div class="input-group">
            <label class="input-label"><%= t('sig_label') %></label>
            <textarea name="yssidSig" class="login-textarea" required rows="2"></textarea>
          </div>
          <button type="submit" class="submit-btn">
            <%= t('btn_login') %>
          </button>
        </form>
      </div>

      <!-- 方法二：Existing ID 登入 -->
      <div class="login-box">
        <div class="tshJ_L" style="margin-bottom: 1rem">
          <%= t('method_2_title') %>
        </div>
        <form method="post" action="/login">
          <input type="hidden" name="method" value="existing" />
          <div class="input-group">
            <label class="input-label"><%= t('uid_label') %></label>
            <input name="uid" class="login-input" type="text" required />
          </div>
          <button type="submit" class="submit-btn">
            <%= t('btn_login') %>
          </button>
        </form>
      </div>

      <!-- 方法三：上傳 JSON 登入 -->
      <div class="login-box">
        <div class="tshJ_L" style="margin-bottom: 1rem">
          <%= t('method_3_title') %>
        </div>
        <form id="uploadForm">
          <input type="hidden" name="method" value="upload" />
          <div class="input-group">
            <label class="input-label">使用者 ID</label>
            <input name="uid" id="uploadUid" class="login-input" type="text" required />
          </div>
          <div class="input-group">
            <label class="input-label"><%= t('file_label') %></label>
            <input name="file" id="uploadFile" class="login-input" style="padding: 0.35rem;" type="file" accept="application/json" required />
          </div>
          <button type="submit" class="submit-btn">
            <%= t('btn_upload_login') %>
          </button>
        </form>
      </div>
    </div>

    <!-- 使用說明 -->
    <div class="x82bAA">
      <div class="tshJ_L"><%= t('instructions_title') %></div>
      <div class="ab1yWq">
        <div class="wYL2n2 Q25EOd"></div>
        <div class="wYL2n2 xW0Sk9"></div>
        <div class="wYL2n2 m8kOmo"></div>
        <div class="wYL2n2 Mric6f"></div>
        <div class="Xo6v7v">
          <div>
            <%- t('instructions_1') %>
          </div>
          <div>
            <%- t('instructions_2') %>
          </div>
        </div>
      </div>
    </div>

    <!-- 工具簡介 (SEO 優化區塊) -->
    <div class="x82bAA">
      <div class="tshJ_L"><%= t('about_title') %></div>
      <div class="ab1yWq">
        <div class="wYL2n2 Q25EOd"></div>
        <div class="wYL2n2 xW0Sk9"></div>
        <div class="wYL2n2 m8kOmo"></div>
        <div class="wYL2n2 Mric6f"></div>
        <div class="Xo6v7v">
          <div style="line-height: 1.6; color: #ccc; margin-bottom: 0.5rem;">
            <%- t('about_desc') %>
          </div>
          <div style="line-height: 1.6; color: #ccc;">
            <%- t('about_features') %>
          </div>
        </div>
      </div>
    </div>

    <!-- 注意事項 -->
    <div class="x82bAA">
      <div class="tshJ_L"><%= t('warning_title') %></div>
      <div class="ab1yWq">
        <div class="wYL2n2 Q25EOd"></div>
        <div class="wYL2n2 xW0Sk9"></div>
        <div class="wYL2n2 m8kOmo"></div>
        <div class="wYL2n2 Mric6f"></div>
        <div class="Xo6v7v">
          <div><%= t('warning_1') %></div>
          <div><%= t('warning_2') %></div>
          <div><%= t('warning_3') %></div>
          <div><%= t('warning_4') %></div>
        </div>
      </div>
    </div>

    <!-- 免責聲明 -->
    <div class="x82bAA">
      <div class="tshJ_L"><%= t('disclaimer_title') %></div>
      <div class="ab1yWq">
        <div class="wYL2n2 Q25EOd"></div>
        <div class="wYL2n2 xW0Sk9"></div>
        <div class="wYL2n2 m8kOmo"></div>
        <div class="wYL2n2 Mric6f"></div>
        <div class="Xo6v7v">
          <div><%= t('disclaimer_1') %></div>
          <div><%= t('disclaimer_2') %></div>
          <div><%= t('disclaimer_3') %></div>
          <div><%= t('disclaimer_4') %></div>
        </div>
      </div>
    </div>

    <!-- 給一個空間防止網頁顯示不全 -->
    <div style="height: 4rem;"></div>

    <!-- 錯誤訊息顯示 -->
    <% if (typeof flash !== 'undefined' && flash) { %>
    <div style="position: fixed; bottom: 1rem; left: 50%; transform: translateX(-50%); background: #ff4444; color: #fff; padding: 0.75rem 1.5rem; border-radius: 0.5rem; z-index: 1000;">
      <%= flash %>
    </div>
    <% } %>

    <!-- 等待遮罩 -->
    <div id="loadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.8); color: #fff; font-size: 1.5rem; text-align: center; line-height: 100vh; z-index: 1000;">
      <%= t('loading_text') %>
    </div>

    <script>
      document.getElementById("cookieForm").addEventListener("submit", function () {
        document.getElementById("loadingOverlay").style.display = "block";
      });

      document.getElementById("uploadForm").addEventListener("submit", async function(e) {
          e.preventDefault();
          document.getElementById("loadingOverlay").style.display = "block";
          
          const uid = document.getElementById("uploadUid").value;
          const fileInput = document.getElementById("uploadFile");
          
          if (!fileInput.files || fileInput.files.length === 0) {
              alert("<%= t('alert_no_file') %>");
              document.getElementById("loadingOverlay").style.display = "none";
              return;
          }
          
          const file = fileInput.files[0];
          const reader = new FileReader();
          reader.onload = async function(evt) {
              try {
                  const logs = JSON.parse(evt.target.result);
                  const res = await fetch('/login', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ method: 'upload', uid: uid, logs: logs })
                  });
                  
                  if (res.redirected) {
                      window.location.href = res.url;
                  } else if (res.ok) {
                      window.location.href = '/';
                  } else {
                      const errorText = await res.text();
                      alert("<%= t('alert_upload_fail') %>" + errorText);
                      document.getElementById("loadingOverlay").style.display = "none";
                  }
              } catch (err) {
                  alert("<%= t('alert_read_fail') %>" + err.message);
                  console.error(err);
                  document.getElementById("loadingOverlay").style.display = "none";
              }
          };
          reader.readAsText(file);
      });
    </script>
    <!-- Global Footer Menu -->
    <div id="footer-menu-container" style="position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 99999; font-family: sans-serif; user-select: none;">
      <div id="footer-menu-links" style="display: none; flex-direction: column; align-items: flex-end; margin-bottom: 0.5rem; gap: 0.5rem;">
        <a href="https://github.com/kaihuang1122/Arknights-txwy-Gacha-Analyze" target="_blank" style="background: rgba(0,0,0,0.8); color: #1bd1fe; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; border: 1px solid #1bd1fe; font-size: 0.9rem; white-space: nowrap; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.2)'" onmouseout="this.style.background='rgba(0,0,0,0.8)'"><%= t('github_code') %></a>
        <a href="/privacy" style="background: rgba(0,0,0,0.8); color: #1bd1fe; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; border: 1px solid #1bd1fe; font-size: 0.9rem; white-space: nowrap; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.2)'" onmouseout="this.style.background='rgba(0,0,0,0.8)'"><%= t('privacy_policy') %></a>
        <a href="javascript:void(0);" onclick="document.body.scrollTo({top: 0, behavior: 'smooth'}); document.documentElement.scrollTo({top: 0, behavior: 'smooth'}); window.scrollTo({top: 0, behavior: 'smooth'});" style="background: rgba(0,0,0,0.8); color: #1bd1fe; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; border: 1px solid #1bd1fe; font-size: 0.9rem; white-space: nowrap; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.2)'" onmouseout="this.style.background='rgba(0,0,0,0.8)'"><%= t('back_to_top') %></a>
      </div>
      <div id="footer-menu-toggle" style="background: rgba(0, 0, 0, 0.8); width: 3rem; height: 3rem; border-radius: 50%; display: flex; justify-content: center; align-items: center; cursor: pointer; border: 2px solid #1bd1fe; float: right; transition: all 0.3s; color: #1bd1fe; font-size: 1.2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
        ▼
      </div>
    </div>
    <script>
      document.getElementById('footer-menu-toggle').addEventListener('click', function(e) {
        const links = document.getElementById('footer-menu-links');
        if (links.style.display === 'none') {
          links.style.display = 'flex';
          this.innerHTML = '▲';
          this.style.background = 'rgba(27, 209, 254, 0.2)';
        } else {
          links.style.display = 'none';
          this.innerHTML = '▼';
          this.style.background = 'rgba(0, 0, 0, 0.8)';
        }
        e.stopPropagation();
      });
      document.addEventListener('click', function(e) {
        const links = document.getElementById('footer-menu-links');
        const toggle = document.getElementById('footer-menu-toggle');
        if (links && links.style.display === 'flex' && !document.getElementById('footer-menu-container').contains(e.target)) {
          links.style.display = 'none';
          toggle.innerHTML = '▼';
          toggle.style.background = 'rgba(0, 0, 0, 0.8)';
        }
      });
    </script>
  </body>
