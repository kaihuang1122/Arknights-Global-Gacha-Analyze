                      <p><%= t('avg_pulls_part1') %><span class="highlight-number"><%= avgPulls %></span><%= t('avg_pulls_part2') %><br/><%= t('avg_cost') %><span class="highlight-number" style="color: #C63A5A"><%= avgCost %></span><%= t('orundum') %></p>
