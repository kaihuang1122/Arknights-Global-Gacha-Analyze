    <style>
      body {
        font-family: "Noto Sans JP", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      }
      .collapsible-content {
        display: none;
      }
      .collapsible-content.open {
        display: block;
      }
      .tshJ_L {
        cursor: pointer;
      }
      /* Dashboard styles */
      .dashboard-panel {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        padding: 1.5rem;
        background: #121212;
        border-radius: 0.5rem;
        margin: 1rem;
        color: #fff;
        font-family: "Noto Sans JP", 'cwTeXHeiBold', 'Heiti TC', sans-serif;
      }
      .dashboard-card {
        flex: 1;
        min-width: 300px;
        padding: 1.5rem;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .dashboard-card h3 {
        margin-top: 0;
        color: #10d1fe;
        font-size: 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        padding-bottom: 0.5rem;
      }
      .dashboard-card p {
        font-size: 1.1rem;
        line-height: 1.6;
        margin: 0.8rem 0;
      }
      .dashboard-card .highlight-number {
        font-size: 1.3rem;
        color: #f7ff00;
        font-weight: bold;
      }
      
      .charts-container {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        justify-content: center;
        align-items: flex-end;
        padding: 1.5rem;
        margin: 1rem;
        background: #121212;
        border-radius: 0.5rem;
      }
      .chart-box {
        width: 250px;
        text-align: center;
      }
      .chart-box h4 {
        color: #fff;
        margin-bottom: 1rem;
        font-size: 1.1rem;
        font-weight: normal;
      }
    </style>
  </head>
