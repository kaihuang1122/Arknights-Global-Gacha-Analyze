                      <p><%= t('invested_part4') %> <span style="color: #f7ff00"><%= allCounts['5'] %></span> <%= t('star_times') %>6<%= t('star') %> (<%= allTotal > 0 ? (allCounts['5']/allTotal*100).toFixed(1) : 0 %>%)，<span style="color: #cc7a00"><%= allCounts['4'] %></span> <%= t('star_times') %>5<%= t('star') %> (<%= allTotal > 0 ? (allCounts['4']/allTotal*100).toFixed(1) : 0 %>%)，<br/>
