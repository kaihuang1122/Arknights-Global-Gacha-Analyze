                  <!-- const categories = ['所有卡池', '限定尋訪', '標準尋訪', '中堅尋訪', '其他尋訪']; -->
                  <% const categories = ['限定尋訪', '標準尋訪', '中堅尋訪', '其他尋訪']; %>
                  <% categories.forEach(function(cat, index) { 
                      let c = stats.starcounts[cat] || { '5': 0, '4': 0, '3': 0, '2': 0 };
                      let total = c['5'] + c['4'] + c['3'] + c['2'];
                      let displayCat = cat === '限定尋訪' ? t('pool_limited') :
                                       cat === '標準尋訪' ? t('pool_standard') :
                                       cat === '中堅尋訪' ? t('pool_kernel') :
                                       t('pool_other');
                      let titleHtml;
                      if (cat === '標準尋訪' || cat === '中堅尋訪') {
                          let subcount = stats.countAcc[cat] || 0;
                          titleHtml = displayCat + `${t('total_pulls_count_prefix')}${total}${t('total_pulls_count_suffix')}<br><span style="font-size: 0.9em; color: #ccc;">${t('pity_acc_prefix')}${subcount}${t('pity_acc_suffix')}</span>`;
                      } else {
                          titleHtml = displayCat + `${t('total_pulls_count_prefix')}${total}${t('total_pulls_count_suffix')}<br><span style="font-size: 0.9em;">&nbsp;</span>`;
                      }
                  %>
