    <!-- </div> -->
    <script>
      // Mobile sidebar toggle
      const mobileBtn = document.querySelector('.uYZr59');
      const sidebar = document.querySelector('.CAmS7u');
      if (mobileBtn && sidebar) {
        mobileBtn.addEventListener('click', () => {
          mobileBtn.classList.toggle('OH5OMA');
          sidebar.classList.toggle('bWI6VY');
        });
      }

      // Accordion effect
      document.querySelectorAll(".tshJ_L").forEach((header) => {
        header.addEventListener("click", () => {
          const content = header.nextElementSibling;
          if (content && content.classList.contains('collapsible-content')) {
            content.classList.toggle("open");
            header.innerHTML = header.innerHTML.endsWith("▼")
              ? header.innerHTML.replace("▼", "▲")
              : header.innerHTML.replace("▲", "▼");
          }
        });
      });

      // Toggle all groups
      function toggleAllGroups(type) {
        const container = document.getElementById(type + '-container');
        if (!container) return;
        
        const headers = container.querySelectorAll('.pool-group-wrapper > .tshJ_L');
        let anyOpen = false;
        
        headers.forEach(h => {
          const content = h.nextElementSibling;
          if (content && content.classList.contains('open')) {
            anyOpen = true;
          }
        });
        
        headers.forEach(h => {
          const content = h.nextElementSibling;
          if (!content) return;
          
          if (anyOpen) {
             // Close all
             if (content.classList.contains('open')) {
               content.classList.remove('open');
               h.innerHTML = h.innerHTML.replace('▲', '▼');
             }
          } else {
             // Open all
             if (!content.classList.contains('open')) {
               content.classList.add('open');
               h.innerHTML = h.innerHTML.replace('▼', '▲');
             }
          }
        });
      }

      // Render Chart.js
      Chart.defaults.color = '#fff';
      Chart.defaults.font.family = "'Noto Sans JP', 'cwTeXHeiBold', 'Heiti TC', sans-serif";
      
      const chartColors = ['#f7ff00', '#cc7a00', '#a231ff', '#19d1ff'];
      const chartLabels = ['6<%= t('star').trim() %>', '5<%= t('star').trim() %>', '4<%= t('star').trim() %>', '3<%= t('star').trim() %>'];
      
      const starcountsData = <%- JSON.stringify(stats.starcounts) %>;
      const categories = ['所有卡池', '限定尋訪', '標準尋訪', '中堅尋訪', '其他尋訪'];
      
      categories.forEach((cat, index) => {
          let c = starcountsData[cat];
          if(c && (c['5'] + c['4'] + c['3'] + c['2'] > 0)) {
              let ctx = document.getElementById('chart-pie-' + index);
              if (ctx) {
                  new Chart(ctx, {
                      type: 'pie',
                      data: {
                          labels: chartLabels,
                          datasets: [{
                              data: [c['5'], c['4'], c['3'], c['2']],
                              backgroundColor: chartColors,
                              hoverOffset: 4,
                              borderWidth: 0
                          }]
                      },
                      options: {
                          responsive: false,
                          plugins: {
                              legend: {
                                  position: 'right',
                                  labels: { color: '#fff' }
                              },
                              tooltip: {
                                  callbacks: {
                                      label: function(context) {
                                          let label = context.label || '';
                                          if (label) { label += ': '; }
                                          if (context.parsed !== null) {
                                              let total = context.dataset.data.reduce((a, b) => a + b, 0);
                                              let percent = ((context.parsed / total) * 100).toFixed(1) + '%';
                                              label += context.parsed + ' (' + percent + ')';
                                          }
                                          return label;
                                      }
                                  }
                              }
                          }
                      }
                  });
              }
          }
      });

      // Checkbox filter functionality
      const cbs = document.querySelectorAll('.pool-filter-cb');
      const toggleAll = document.getElementById('filter-pool-all');

      if (toggleAll) {
        toggleAll.addEventListener('change', function() {
          const show = this.checked;
          cbs.forEach(cb => {
            if (cb.checked !== show) {
              cb.checked = show;
              cb.dispatchEvent(new Event('change'));
            }
          });
        });
      }

      cbs.forEach(cb => {
        cb.addEventListener('change', function() {
          const poolName = this.value;
          const show = this.checked;
          
          if (toggleAll) {
            const allChecked = Array.from(cbs).every(c => c.checked);
            const someChecked = Array.from(cbs).some(c => c.checked);
            toggleAll.checked = allChecked;
            toggleAll.indeterminate = someChecked && !allChecked;
          }

          document.querySelectorAll(`.pool-group-wrapper[data-pool="${poolName}"]`).forEach(wrapper => {
            wrapper.style.display = show ? 'block' : 'none';
          });
        });
      });
    </script>
    <!-- Global Footer Menu -->
    <div id="footer-menu-container" style="position: fixed; bottom: 1.5rem; right: 1.5rem; z-index: 99999; font-family: sans-serif; user-select: none;">
      <div id="footer-menu-links" style="display: none; flex-direction: column; align-items: flex-end; margin-bottom: 0.5rem; gap: 0.5rem;">
        <a href="https://github.com/kaihuang1122/Arknights-txwy-Gacha-Analyze" target="_blank" style="background: rgba(0,0,0,0.8); color: #1bd1fe; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; border: 1px solid #1bd1fe; font-size: 0.9rem; white-space: nowrap; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.2)'" onmouseout="this.style.background='rgba(0,0,0,0.8)'"><%= t('github_code') %></a>
        <a href="/privacy" style="background: rgba(0,0,0,0.8); color: #1bd1fe; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; border: 1px solid #1bd1fe; font-size: 0.9rem; white-space: nowrap; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.2)'" onmouseout="this.style.background='rgba(0,0,0,0.8)'"><%= t('privacy_policy') %></a>
        <a href="javascript:void(0);" onclick="document.body.scrollTo({top: 0, behavior: 'smooth'}); document.documentElement.scrollTo({top: 0, behavior: 'smooth'}); window.scrollTo({top: 0, behavior: 'smooth'});" style="background: rgba(0,0,0,0.8); color: #1bd1fe; padding: 0.6rem 1.2rem; border-radius: 4px; text-decoration: none; border: 1px solid #1bd1fe; font-size: 0.9rem; white-space: nowrap; font-weight: bold; transition: background 0.3s;" onmouseover="this.style.background='rgba(27,209,254,0.2)'" onmouseout="this.style.background='rgba(0,0,0,0.8)'"><%= t('back_to_top') %></a>
      </div>
      <div id="footer-menu-toggle" style="background: rgba(0, 0, 0, 0.8); width: 3rem; height: 3rem; border-radius: 50%; display: flex; justify-content: center; align-items: center; cursor: pointer; border: 2px solid #1bd1fe; float: right; transition: all 0.3s; color: #1bd1fe; font-size: 1.2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
        ▼
      </div>
    </div>
    <script>
      document.getElementById('footer-menu-toggle').addEventListener('click', function(e) {
        const links = document.getElementById('footer-menu-links');
        if (links.style.display === 'none') {
          links.style.display = 'flex';
          this.innerHTML = '▲';
          this.style.background = 'rgba(27, 209, 254, 0.2)';
        } else {
          links.style.display = 'none';
          this.innerHTML = '▼';
          this.style.background = 'rgba(0, 0, 0, 0.8)';
        }
        e.stopPropagation();
      });
      document.addEventListener('click', function(e) {
        const links = document.getElementById('footer-menu-links');
        const toggle = document.getElementById('footer-menu-toggle');
        if (links && links.style.display === 'flex' && !document.getElementById('footer-menu-container').contains(e.target)) {
          links.style.display = 'none';
          toggle.innerHTML = '▼';
          toggle.style.background = 'rgba(0, 0, 0, 0.8)';
        }
      });
    </script>
  </body>
</html>
